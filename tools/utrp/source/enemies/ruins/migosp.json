{
  "format": "utrp",
  "version": 1,
  "slug": "ruins/migosp",
  "name": "Migosp",
  "fps": 30,
  "canvas": {
    "width": 184,
    "height": 236,
    "scale": 2
  },
  "coordinate_space": {
    "origin": "top_left",
    "y_axis": "down",
    "rotation": "counter_clockwise",
    "angle_unit": "degrees"
  },
  "review": {
    "accuracy": "needs_source_review",
    "notes": [
      "Converted to UTRP from the site's previous animation data. Needs comparison against UNDERTALE source before being marked exact.",
      "Previous animation data included states (happy, normal); state switching awaits the UTRP runtime state model."
    ]
  },
  "variables": [
    {
      "name": "siner",
      "kind": "counter",
      "initial": 1.0
    },
    {
      "name": "init",
      "kind": "counter",
      "initial": 0.0
    },
    {
      "name": "alarm",
      "kind": "counter",
      "initial": 0.0
    },
    {
      "name": "active",
      "kind": "counter",
      "initial": 0.0
    },
    {
      "name": "active_timer",
      "kind": "counter",
      "initial": 0.0
    },
    {
      "name": "trigger",
      "kind": "counter",
      "initial": 0.0
    },
    {
      "name": "stop",
      "kind": "counter",
      "initial": 0.0
    },
    {
      "name": "image_index",
      "kind": "counter",
      "initial": 0.0
    }
  ],
  "assets": [
    {
      "id": "migosp_body",
      "path": "/sprites/migosp/body_0.png",
      "frames": [
        "/sprites/migosp/body_0.png",
        "/sprites/migosp/body_1.png"
      ]
    }
  ],
  "update": [
    {
      "op": "increment",
      "variable": "siner",
      "by": "1"
    },
    {
      "op": "set",
      "variable": "alarm",
      "value": "ifelse(eq(init, 0), 20 + random(40), alarm)"
    },
    {
      "op": "set",
      "variable": "init",
      "value": "1"
    },
    {
      "op": "increment",
      "variable": "alarm",
      "by": "ifelse(eq(active, 0), -1, 0)"
    },
    {
      "op": "set",
      "variable": "trigger",
      "value": "eq(active, 0) * lte(alarm, 0)"
    },
    {
      "op": "set",
      "variable": "active",
      "value": "ifelse(trigger, 1, active)"
    },
    {
      "op": "set",
      "variable": "active_timer",
      "value": "ifelse(trigger, 0, active_timer)"
    },
    {
      "op": "increment",
      "variable": "image_index",
      "by": "ifelse(eq(active, 1), 0.5, 0)"
    },
    {
      "op": "increment",
      "variable": "active_timer",
      "by": "ifelse(eq(active, 1), 1, 0)"
    },
    {
      "op": "set",
      "variable": "stop",
      "value": "eq(active, 1) * gte(active_timer, 10)"
    },
    {
      "op": "set",
      "variable": "active",
      "value": "ifelse(stop, 0, active)"
    },
    {
      "op": "set",
      "variable": "alarm",
      "value": "ifelse(stop, 30 + random(40), alarm)"
    },
    {
      "op": "set",
      "variable": "active_timer",
      "value": "ifelse(stop, 0, active_timer)"
    }
  ],
  "draw": [
    {
      "kind": "sprite",
      "id": "body",
      "sprite": "migosp_body",
      "origin": {
        "x": 0,
        "y": 0
      },
      "pivot": null,
      "transform": {
        "frame_index": "floor(image_index)"
      },
      "draw_order": 0
    }
  ]
}
