{
  "format": "utrp",
  "version": 1,
  "slug": "ruins/migosp",
  "name": "Migosp",
  "fps": 30,
  "canvas": {
    "width": 184,
    "height": 236,
    "scale": 1
  },
  "coordinate_space": {
    "origin": "top_left",
    "y_axis": "down",
    "rotation": "counter_clockwise",
    "angle_unit": "degrees"
  },
  "review": {
    "accuracy": "needs_source_review",
    "notes": [
      "Normal state models GM Alarm_7/Alarm_8 as a deterministic 50-step equivalent: 10 steps of image_speed=0.5, then stopped until the next start. GM uses 30+random(40) for the next start, so exact random cadence is not represented.",
      "GM switches to spr_migosphappy when mercymod > 0. happy_state is exposed as a data variable for future runtime state control; default remains normal."
    ]
  },
  "variables": [
    {
      "name": "siner",
      "kind": "counter",
      "initial": 1.0
    },
    {
      "name": "happy_state",
      "kind": "counter",
      "initial": 0.0
    }
  ],
  "assets": [
    {
      "id": "migosp_body",
      "path": "/sprites/migosp/body_0.png",
      "frames": [
        "/sprites/migosp/body_0.png",
        "/sprites/migosp/body_1.png"
      ]
    },
    {
      "id": "migosp_happy",
      "path": "/sprites/migosp/happy_0.png",
      "frames": [
        "/sprites/migosp/happy_0.png",
        "/sprites/migosp/happy_1.png"
      ]
    }
  ],
  "update": [
    {
      "op": "increment",
      "variable": "siner",
      "by": "1"
    }
  ],
  "draw": [
    {
      "kind": "sprite",
      "id": "body",
      "sprite": "migosp_body",
      "origin": {
        "x": 0,
        "y": 0
      },
      "pivot": null,
      "transform": {
        "alpha": "1 - happy_state",
        "frame_index": "floor((floor(siner / 50) * 10 + min(siner % 50, 10)) * 0.5) % 2"
      },
      "draw_order": 0
    },
    {
      "kind": "sprite",
      "id": "happy_body",
      "sprite": "migosp_happy",
      "origin": {
        "x": 0,
        "y": 0
      },
      "pivot": null,
      "transform": {
        "alpha": "happy_state",
        "frame_index": "floor(siner * 0.1) % 2"
      },
      "draw_order": 1
    }
  ]
}
