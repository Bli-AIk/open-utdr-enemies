{
  "format": "utrp",
  "version": 1,
  "slug": "ruins/moldsmal",
  "name": "Moldsmal",
  "fps": 30,
  "canvas": {
    "width": 244,
    "height": 208,
    "scale": 1
  },
  "coordinate_space": {
    "origin": "top_left",
    "y_axis": "down",
    "rotation": "counter_clockwise",
    "angle_unit": "degrees"
  },
  "review": {
    "accuracy": "reviewed",
    "notes": [
      "Idle follows GM scalevalue/image_yscale triangle wave: scalevalue flips only after passing 0.9/1.1, includes the one-frame 0.89/1.11 overshoot, image_speed remains 0, and y is compensated by 102 * (1 - image_yscale)."
    ]
  },
  "variables": [
    {
      "name": "siner",
      "kind": "counter",
      "initial": 1.0
    },
    {
      "name": "moldsmal_scale",
      "kind": "counter",
      "initial": 1.0
    }
  ],
  "assets": [
    {
      "id": "moldsmal_body",
      "path": "/sprites/moldsmal/body_0.png",
      "frames": [
        "/sprites/moldsmal/body_0.png",
        "/sprites/moldsmal/body_1.png"
      ]
    }
  ],
  "update": [
    {
      "op": "increment",
      "variable": "siner",
      "by": "1"
    },
    {
      "op": "set",
      "variable": "moldsmal_scale",
      "value": "ifelse(lte((siner - 1) % 44, 11), 1 - ((siner - 1) % 44) * 0.01, ifelse(lte((siner - 1) % 44, 33), 0.89 + (((siner - 1) % 44) - 11) * 0.01, 1.11 - (((siner - 1) % 44) - 33) * 0.01))"
    }
  ],
  "draw": [
    {
      "kind": "sprite",
      "id": "body",
      "sprite": "moldsmal_body",
      "origin": {
        "x": 0,
        "y": 0
      },
      "pivot": {
        "x": 0,
        "y": 0
      },
      "transform": {
        "offset_y": "102 * (1 - moldsmal_scale)",
        "scale_y": "moldsmal_scale",
        "frame_index": "0"
      },
      "draw_order": 0
    }
  ]
}
