      "variable": "eyey_draw",
      "value": "eyey"
    },
    {
      "op": "increment",
      "variable": "mouth_index",
      "by": "ifelse(gte(timer, 40) * lte(timer, 50), 0.5, 0)"
    },
    {
      "op": "set",
      "variable": "mouth_index",
      "value": "ifelse(eq(timer, 51), 0, mouth_index)"
    },
    {
      "op": "set",
      "variable": "timer",
      "value": "ifelse(eq(timer, 51), 0, timer)"
    },
    {
      "op": "increment",
      "variable": "eyey",
      "by": "ifelse(gt(timer_e, 90) * lte(timer_e, 110), -0.8, 0)"
    },
    {
      "op": "increment",
      "variable": "eyey",
      "by": "ifelse(gt(timer_e, 150) * lte(timer_e, 170), 0.8, 0)"
    },
    {
      "op": "set",
      "variable": "timer_e",
      "value": "ifelse(eq(timer_e, 180), 0, timer_e)"
    }
  ],
