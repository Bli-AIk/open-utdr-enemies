      },
      "transform": {
        "offset_x": "-sin(siner / 6) * 2 * sfactor",
        "offset_y": "-cos(siner / 6) * 2 * sfactor",
        "scale_x": "-1",
        "scale_y": "0.95 - cos(siner / 6) * 0.1 * sfactor",
        "frame_index": "floor(anim2 / 3)"
      },
      "draw_order": 2
    },
    {
      "kind": "sprite",
      "id": "leg_right",
      "sprite": "astigmatism_legl",
      "origin": {
        "x": 22,
