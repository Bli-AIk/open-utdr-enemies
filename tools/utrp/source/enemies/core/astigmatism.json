      },
      "pivot": {
        "x": 1,
        "y": 0
      },
      "transform": {
        "offset_x": "cos(siner / 6) * 2 * sfactor",
        "offset_y": "sin(siner / 6) * 2 * sfactor",
        "scale_y": "0.9 + sin(siner / 6) * 0.1 * sfactor",
        "frame_index": "floor(anim2 / 3)"
      },
      "draw_order": 1
    },
    {
      "kind": "sprite",
      "id": "hand_right",
      "sprite": "astigmatism_handl",
      "origin": {
        "x": 44,
