  "update": [
    {
      "op": "increment",
      "variable": "siner",
      "by": "1"
    },
    {
      "op": "increment",
      "variable": "anim_e",
      "by": "1"
    },
    {
      "op": "increment",
      "variable": "anim_e2",
      "by": "ifelse(gt(anim_e, 30) * lt(anim_e, 60), 1, 0)"
    },
    {
      "op": "set",
      "variable": "anim_e2",
      "value": "ifelse(gt(anim_e, 180), 0, anim_e2)"
    },
    {
      "op": "set",
      "variable": "anim_e",
      "value": "ifelse(gt(anim_e, 180), 0, anim_e)"
    },
    {
      "op": "increment",
      "variable": "anim_l",
      "by": "1"
    },
    {
      "op": "increment",
      "variable": "anim_l2",
      "by": "ifelse(gte(anim_l, 60) * lt(anim_l, 120), -0.5, 0)"
    },
    {
      "op": "increment",
      "variable": "anim_l2",
      "by": "ifelse(gte(anim_l, 150) * lt(anim_l, 300), 6, 0)"
    },
    {
      "op": "set",
      "variable": "anim_l2",
      "value": "ifelse(gte(anim_l, 150) * lt(anim_l, 300) * gte(anim_l2, 0), 0, anim_l2)"
    },
    {
      "op": "set",
      "variable": "anim_l",
      "value": "ifelse(gte(anim_l, 150) * lt(anim_l, 300) * gte(anim_l2, 0), 300, anim_l)"
    },
    {
      "op": "set",
      "variable": "anim_l3",
      "value": "ifelse(gte(anim_l, 300), ifelse(eq(anim_l2, 0), 0, ifelse(eq(anim_l3, 0), choose(-1, 1), anim_l3)), anim_l3)"
    },
    {
      "op": "set",
      "variable": "anim_l2",
      "value": "ifelse(gte(anim_l, 300), ifelse(eq(anim_l2, 0), -3, 0), anim_l2)"
    },
    {
      "op": "set",
      "variable": "anim_l3",
      "value": "ifelse(gt(anim_l, 310), 0, anim_l3)"
    },
    {
      "op": "set",
      "variable": "anim_l2",
      "value": "ifelse(gt(anim_l, 310), 0, anim_l2)"
    },
    {
      "op": "set",
      "variable": "anim_l",
      "value": "ifelse(gt(anim_l, 310), 0, anim_l)"
    },
    {
      "op": "increment",
      "variable": "anim_h",
      "by": "1"
    },
    {
      "op": "increment",
      "variable": "anim_h2",
      "by": "ifelse(gt(anim_h, 50) * lt(anim_h, 75), 1, 0)"
    },
    {
      "op": "set",
      "variable": "anim_h",
      "value": "ifelse(gt(anim_h, 100), 0, anim_h)"
    },
    {
      "op": "increment",
      "variable": "anim_m",
      "by": "1"
    },
    {
      "op": "increment",
      "variable": "anim_m2",
      "by": "ifelse(gt(anim_m, 150) * lt(anim_m, 180), 1, 0)"
    },
    {
      "op": "increment",
      "variable": "anim_m2",
      "by": "ifelse(gt(anim_m, 240) * lt(anim_m, 270), 1, 0)"
    },
    {
      "op": "set",
      "variable": "anim_m2",
      "value": "ifelse(gt(anim_m, 300), 0, anim_m2)"
    },
    {
      "op": "set",
      "variable": "anim_m",
      "value": "ifelse(gt(anim_m, 300), 0, anim_m)"
    }
