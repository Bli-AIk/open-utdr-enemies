  "update": [
    {
      "op": "increment",
      "variable": "siner",
      "by": "1"
    },
    {
      "op": "increment",
      "variable": "tick",
      "by": "1"
    },
    {
      "op": "set",
      "variable": "anim_e2",
      "value": "ifelse(lt(tick % 181, 31), 0, ifelse(lt(tick % 181, 60), (tick % 181) - 30, 29))"
    },
    {
      "op": "set",
      "variable": "anim_h2",
      "value": "floor(tick / 101) * 24 + clamp((tick % 101) - 50, 0, 24)"
    },
    {
      "op": "set",
      "variable": "anim_m2",
      "value": "ifelse(lt(tick % 301, 151), 0, ifelse(lt(tick % 301, 180), (tick % 301) - 150, ifelse(lt(tick % 301, 241), 29, ifelse(lt(tick % 301, 270), 29 + (tick % 301) - 240, 58))))"
    },
    {
      "op": "set",
      "variable": "anim_l2",
      "value": "ifelse(lt(tick % 165, 60), 0, ifelse(lt(tick % 165, 120), -((tick % 165) - 59) * 0.5, ifelse(lt(tick % 165, 150), -30, ifelse(lt(tick % 165, 155), min(0, -30 + ((tick % 165) - 149) * 6), ifelse(eq((tick % 165) % 2, 0), 0, -3)))))"
    },
    {
      "op": "set",
      "variable": "anim_l3",
      "value": "ifelse(gte(tick % 165, 155), ifelse(eq((tick % 4), 0), -1, 1), 0)"
    }
  ],
  "draw": [
