{
  "format": "utrp",
  "version": 1,
  "slug": "hotland/tsunderplane",
  "name": "Tsunderplane",
  "fps": 30,
  "canvas": {
    "width": 230,
    "height": 194,
    "scale": 1
  },
  "coordinate_space": {
    "origin": "top_left",
    "y_axis": "down",
    "rotation": "counter_clockwise",
    "angle_unit": "degrees"
  },
  "review": {
    "accuracy": "reviewed",
    "notes": [
      "Reviewed against obj_tsunderplane_body_Draw_0/Create_0 and obj_tsunderplane_Create_0. Default idle preserves the GM body/hat 2x scale and shared siner / 7 vertical bob.",
      "Graze blush, falling, and explosion states are conditional event states and are not part of this default idle renderer."
    ]
  },
  "variables": [
    {
      "name": "siner",
      "kind": "counter",
      "initial": 1.0
    }
  ],
  "assets": [
    {
      "id": "tsunderplane_body",
      "path": "/sprites/tsunderplane/body.png",
      "frames": [
        "/sprites/tsunderplane/body.png"
      ]
    },
    {
      "id": "tsunderplane_hat",
      "path": "/sprites/tsunderplane/hat.png",
      "frames": [
        "/sprites/tsunderplane/hat.png"
      ]
    }
  ],
  "update": [
    {
      "op": "increment",
      "variable": "siner",
      "by": "1"
    }
  ],
  "draw": [
    {
      "kind": "sprite",
      "id": "body",
      "sprite": "tsunderplane_body",
      "origin": {
        "x": 0,
        "y": 0
      },
      "pivot": null,
      "transform": {
        "offset_y": "sin(siner / 7) * 3",
        "scale_x": "2",
        "scale_y": "2"
      },
      "draw_order": 0
    },
    {
      "kind": "sprite",
      "id": "hat",
      "sprite": "tsunderplane_hat",
      "origin": {
        "x": 57,
        "y": -15
      },
      "pivot": null,
      "transform": {
        "offset_y": "sin(siner / 7) * 3",
        "scale_x": "2",
        "scale_y": "2"
      },
      "draw_order": 1
    }
  ]
}
