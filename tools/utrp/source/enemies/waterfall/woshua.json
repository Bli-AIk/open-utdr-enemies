      ]
    }
  ],
  "update": [
    {
      "op": "increment",
      "variable": "siner",
      "by": "1"
    },
    {
      "op": "increment",
      "variable": "anim",
      "by": "0.2"
    },
    {
      "op": "increment",
      "variable": "tick",
      "by": "1"
    },
    {
      "op": "increment",
      "variable": "fy",
      "by": "ifelse(eq(tick % 5, 0), fu, 0)"
    },
    {
      "op": "increment",
      "variable": "hy",
      "by": "ifelse(eq(tick % 5, 0), -fu / 2, 0)"
    },
    {
      "op": "set",
      "variable": "fu",
      "value": "ifelse(gt(fy, 3), -2, ifelse(lt(fy, -6), 2, fu))"
    },
    {
      "op": "increment",
      "variable": "waterxx",
      "by": "ifelse(eq(tick % 5, 0), wu, 0)"
    },
    {
      "op": "set",
      "variable": "wu",
      "value": "ifelse(gt(waterxx, 15), -1, ifelse(lt(waterxx, 1), 1, wu))"
    },
    {
      "op": "increment",
      "variable": "ducky",
      "by": "ifelse(eq(tick % 5, 0), -wu, 0)"
    }
  ],
  "draw": [
