  "update": [
    {
      "op": "increment",
      "variable": "siner",
      "by": "1.0"
    },
    {
      "op": "increment",
      "variable": "tick",
      "by": "1.0"
    },
    {
      "op": "set",
      "variable": "anim_e2",
      "value": "ifelse(lt(tick % 181.0, 31.0), 0.0, ifelse(lt(tick % 181.0, 60.0), tick % 181.0 - 30.0, 29.0))"
    },
    {
      "op": "set",
      "variable": "anim_h2",
      "value": "floor(tick / 101.0) * 24.0 + clamp(tick % 101.0 - 50.0, 0.0, 24.0)"
    },
    {
      "op": "set",
      "variable": "anim_m2",
      "value": "ifelse(lt(tick % 301.0, 151.0), 0.0, ifelse(lt(tick % 301.0, 180.0), tick % 301.0 - 150.0, ifelse(lt(tick % 301.0, 241.0), 29.0, ifelse(lt(tick % 301.0, 270.0), 29.0 + tick % 301.0 - 240.0, 58.0))))"
    },
    {
      "op": "set",
      "variable": "anim_l2",
      "value": "ifelse(lt(tick % 165.0, 60.0), 0.0, ifelse(lt(tick % 165.0, 120.0), -(tick % 165.0 - 59.0) * 0.5, ifelse(lt(tick % 165.0, 150.0), -30.0, ifelse(lt(tick % 165.0, 155.0), min(0.0, -30.0 + (tick % 165.0 - 149.0) * 6.0), ifelse(eq(tick % 165.0 % 2.0, 0.0), 0.0, -3.0)))))"
    },
    {
      "op": "set",
      "variable": "anim_l3",
      "value": "ifelse(gte(tick % 165.0, 155.0), ifelse(eq(tick % 4.0, 0.0), -1.0, 1.0), 0.0)"
    }
  ],
