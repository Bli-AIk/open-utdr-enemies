{
  "name": "Knight Knight",
  "fps": 30,
  "scale": 2,
  "canvasWidth": 224,
  "canvasHeight": 332,
  "variables": {
    "siner": {
      "type": "counter",
      "step": 1
    }
  },
  "sprites": {
    "knightknight_leftarm": "/sprites/knight-knight/knightknight_leftarm.png",
    "knightknight_fur": "/sprites/knight-knight/knightknight_fur.png",
    "knightknight_body": "/sprites/knight-knight/knightknight_body.png",
    "knightknight_eyes": "/sprites/knight-knight/knightknight_eyes.png",
    "knightknight_helmet": "/sprites/knight-knight/knightknight_helmet.png",
    "knightknight_mouth": "/sprites/knight-knight/knightknight_mouth.png"
  },
  "parts": [
    {
      "id": "eyes",
      "sprite": "knightknight_eyes",
      "origin": { "x": -11, "y": -31 },
      "pivot": { "x": 1, "y": 0 },
      "drawOrder": 0,
      "expressions": {
        "offset_x": "sin(siner / 10) * 6"
      }
    },
    {
      "id": "body",
      "sprite": "knightknight_body",
      "origin": { "x": -105, "y": -101 },
      "pivot": { "x": -24, "y": -17 },
      "drawOrder": 1
    },
    {
      "id": "helmet",
      "sprite": "knightknight_helmet",
      "origin": { "x": -35, "y": -99 },
      "pivot": { "x": -1, "y": -2 },
      "drawOrder": 2
    },
    {
      "id": "mouth",
      "sprite": "knightknight_mouth",
      "origin": { "x": -7, "y": -17 },
      "pivot": { "x": 0, "y": -3 },
      "drawOrder": 3
    },
    {
      "id": "fur",
      "sprite": "knightknight_fur",
      "origin": { "x": -41, "y": -5 },
      "pivot": { "x": 1, "y": 0 },
      "drawOrder": 4
    },
    {
      "id": "leftarm",
      "sprite": "knightknight_leftarm",
      "origin": { "x": -105, "y": -101 },
      "pivot": { "x": 1, "y": -1 },
      "drawOrder": 5
    }
  ]
}