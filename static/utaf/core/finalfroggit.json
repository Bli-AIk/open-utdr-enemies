{
  "name": "Final Froggit",
  "fps": 30,
  "scale": 2,
  "canvasWidth": 180,
  "canvasHeight": 170,
  "variables": {
    "siner": {
      "type": "counter",
      "step": 1
    }
  },
  "sprites": {
    "finalfroggit_body": "/sprites/finalfroggit/body.png",
    "finalfroggit_head": "/sprites/finalfroggit/head.png",
    "finalfroggit_head_hurt": "/sprites/finalfroggit/head_hurt.png"
  },
  "parts": [
    {
      "id": "body",
      "sprite": "finalfroggit_body",
      "origin": {
        "x": 0,
        "y": 63
      },
      "pivot": {
        "x": 25,
        "y": 25
      },
      "drawOrder": 0,
      "expressions": {
        "scale_y": "1.0 + sin(siner / 3) * -0.075"
      }
    },
    {
      "id": "head",
      "sprite": "finalfroggit_head",
      "origin": {
        "x": 0,
        "y": -27
      },
      "drawOrder": 1,
      "expressions": {
        "offset_x": "sin(siner / 6) * 10",
        "offset_y": "sin(siner / 3) * 4",
        "rotation": "sin(siner / 6) * -2"
      }
    }
  ]
}