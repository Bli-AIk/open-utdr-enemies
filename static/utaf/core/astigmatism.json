{
  "name": "Astigmatism",
  "fps": 30,
  "scale": 2,
  "canvasWidth": 222,
  "canvasHeight": 268,
  "variables": {
    "siner": {
      "type": "counter",
      "step": 1
    }
  },
  "sprites": {
    "astigmatism_handl": "/sprites/astigmatism/handl.png",
    "astigmatism_legl": "/sprites/astigmatism/legl.png",
    "astigmatism_body": "/sprites/astigmatism/body.png"
  },
  "parts": [
    {
      "id": "hand_left",
      "sprite": "astigmatism_handl",
      "origin": { "x": -40, "y": 6 },
      "pivot": { "x": 1, "y": 0 },
      "drawOrder": 0,
      "expressions": {
        "offset_x": "sin(siner / 6) * 2",
        "offset_y": "cos(siner / 6) * 2",
        "scale_y": "0.9 + cos(siner / 6) * 0.1"
      }
    },
    {
      "id": "leg_left",
      "sprite": "astigmatism_legl",
      "origin": { "x": -18, "y": 26 },
      "pivot": { "x": 1, "y": 0 },
      "drawOrder": 1,
      "expressions": {
        "offset_x": "cos(siner / 6) * 2",
        "offset_y": "sin(siner / 6) * 2",
        "scale_y": "0.9 + sin(siner / 6) * 0.1"
      }
    },
    {
      "id": "hand_right",
      "sprite": "astigmatism_handl",
      "origin": { "x": 44, "y": 6 },
      "pivot": { "x": 1, "y": 0 },
      "drawOrder": 2,
      "expressions": {
        "scale_x": "-1",
        "offset_x": "-sin(siner / 6) * 2",
        "offset_y": "-cos(siner / 6) * 2",
        "scale_y": "0.95 - cos(siner / 6) * 0.1"
      }
    },
    {
      "id": "leg_right",
      "sprite": "astigmatism_legl",
      "origin": { "x": 22, "y": 26 },
      "pivot": { "x": 1, "y": 0 },
      "drawOrder": 3,
      "expressions": {
        "scale_x": "-1",
        "offset_x": "-cos(siner / 6) * 2",
        "offset_y": "-sin(siner / 6) * 2",
        "scale_y": "0.9 - sin(siner / 6) * 0.1"
      }
    },
    {
      "id": "body",
      "sprite": "astigmatism_body",
      "origin": { "x": -48, "y": -58 },
      "pivot": { "x": 1, "y": 0 },
      "drawOrder": 4
    }
  ]
}