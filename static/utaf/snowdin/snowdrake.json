{
  "name": "Snowdrake",
  "fps": 30,
  "scale": 2,
  "canvasWidth": 172,
  "canvasHeight": 210,
  "variables": {
    "siner": {
      "type": "counter",
      "step": 1
    }
  },
  "sprites": {
    "snowdrake_legs": "/sprites/snowdrake/legs.png",
    "snowdrake_body": "/sprites/snowdrake/body.png",
    "snowdrake_head": [
      "/sprites/snowdrake/head_0.png",
      "/sprites/snowdrake/head_1.png",
      "/sprites/snowdrake/head_2.png",
      "/sprites/snowdrake/head_3.png",
      "/sprites/snowdrake/head_4.png",
      "/sprites/snowdrake/head_5.png",
      "/sprites/snowdrake/head_6.png",
      "/sprites/snowdrake/head_7.png",
      "/sprites/snowdrake/head_8.png",
      "/sprites/snowdrake/head_9.png",
      "/sprites/snowdrake/head_10.png",
      "/sprites/snowdrake/head_11.png",
      "/sprites/snowdrake/head_12.png",
      "/sprites/snowdrake/head_13.png",
      "/sprites/snowdrake/head_14.png",
      "/sprites/snowdrake/head_15.png",
      "/sprites/snowdrake/head_16.png",
      "/sprites/snowdrake/head_17.png",
      "/sprites/snowdrake/head_18.png",
      "/sprites/snowdrake/head_19.png"
    ]
  },
  "parts": [
    {
      "id": "legs",
      "sprite": "snowdrake_legs",
      "origin": { "x": -86, "y": -100 },
      "pivot": { "x": 0, "y": 0 },
      "drawOrder": 0
    },
    {
      "id": "body",
      "sprite": "snowdrake_body",
      "origin": { "x": -86, "y": -100 },
      "pivot": { "x": 0, "y": 0 },
      "drawOrder": 1,
      "expressions": {
        "offset_y": "sin(siner / 13) * 3.3"
      }
    },
    {
      "id": "head",
      "sprite": "snowdrake_head",
      "origin": { "x": -86, "y": -100 },
      "pivot": { "x": 0, "y": 0 },
      "drawOrder": 2,
      "expressions": {
        "offset_y": "sin(siner / 13) * 10",
        "frame_index": "floor(siner * 0.1) % 20"
      }
    }
  ]
}