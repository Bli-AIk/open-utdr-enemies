{
  "name": "Gyftrot",
  "fps": 30,
  "scale": 2,
  "canvasWidth": 230,
  "canvasHeight": 220,
  "variables": {
    "siner": { "type": "counter", "step": 1 }
  },
  "sprites": {
    "gyftrot_body": "/sprites/gyftrot/body.png",
    "gyftrot_head": [
      "/sprites/gyftrot/head_0.png",
      "/sprites/gyftrot/head_1.png"
    ],
    "gyftrot_mouth": [
      "/sprites/gyftrot/mouth_0.png",
      "/sprites/gyftrot/mouth_1.png",
      "/sprites/gyftrot/mouth_2.png",
      "/sprites/gyftrot/mouth_3.png",
      "/sprites/gyftrot/mouth_4.png",
      "/sprites/gyftrot/mouth_5.png",
      "/sprites/gyftrot/mouth_6.png",
      "/sprites/gyftrot/mouth_7.png",
      "/sprites/gyftrot/mouth_8.png"
    ],
    "gyftrot_gift": [
      "/sprites/gyftrot/gift_0.png",
      "/sprites/gyftrot/gift_1.png",
      "/sprites/gyftrot/gift_2.png",
      "/sprites/gyftrot/gift_3.png",
      "/sprites/gyftrot/gift_4.png",
      "/sprites/gyftrot/gift_5.png",
      "/sprites/gyftrot/gift_6.png",
      "/sprites/gyftrot/gift_7.png",
      "/sprites/gyftrot/gift_8.png",
      "/sprites/gyftrot/gift_9.png"
    ]
  },
  "parts": [
    {
      "id": "body",
      "sprite": "gyftrot_body",
      "origin": { "x": -100, "y": -103 },
      "pivot": { "x": 1, "y": 0 },
      "drawOrder": 0
    },
    {
      "id": "gift",
      "sprite": "gyftrot_gift",
      "origin": { "x": -100, "y": -103 },
      "pivot": { "x": 1, "y": 0 },
      "drawOrder": 1,
      "expressions": {
        "offset_x": "sin(siner / 15) * 8",
        "frame_index": "floor(siner * 0.02) % 10"
      }
    },
    {
      "id": "head",
      "sprite": "gyftrot_head",
      "origin": { "x": -100, "y": -103 },
      "pivot": { "x": 1, "y": 0 },
      "drawOrder": 2,
      "expressions": {
        "offset_x": "sin(siner / 15) * 8",
        "frame_index": "clamp(sign(sin(siner / 40) - 0.9), 0, 1)"
      }
    },
    {
      "id": "mouth",
      "sprite": "gyftrot_mouth",
      "origin": { "x": -50, "y": -7 },
      "pivot": { "x": 1, "y": 0 },
      "drawOrder": 3,
      "expressions": {
        "offset_x": "sin(siner / 15) * 8",
        "frame_index": "floor(clamp(5 - abs(siner % 100 - 15) / 3, 0, 4))"
      }
    }
  ]
}