{
  "name": "Loox",
  "fps": 30,
  "scale": 2,
  "canvasWidth": 240,
  "canvasHeight": 272,
  "variables": {
    "siner": {
      "type": "counter",
      "step": 1
    }
  },
  "sprites": {
    "loox_body": [
      "/sprites/loox/body_0.png",
      "/sprites/loox/body_1.png",
      "/sprites/loox/body_2.png",
      "/sprites/loox/body_3.png",
      "/sprites/loox/body_4.png"
    ]
  },
  "parts": [
    {
      "id": "body",
      "sprite": "loox_body",
      "origin": {
        "x": 0,
        "y": 0
      },
      "drawOrder": 0,
      "expressions": {
        "frame_index": "floor(clamp(siner % 30 - 20, 0, 10) * 0.5)"
      }
    }
  ]
}