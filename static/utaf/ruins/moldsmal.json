{
  "name": "Moldsmal",
  "fps": 30,
  "scale": 2,
  "canvasWidth": 244,
  "canvasHeight": 208,
  "variables": {
    "siner": {
      "type": "counter",
      "step": 1
    }
  },
  "sprites": {
    "moldsmal_body": [
      "/sprites/moldsmal/body_0.png",
      "/sprites/moldsmal/body_1.png"
    ]
  },
  "parts": [
    {
      "id": "body",
      "sprite": "moldsmal_body",
      "origin": {
        "x": 0,
        "y": 0
      },
      "drawOrder": 0,
      "expressions": {
        "frame_index": "floor(siner / 6) % 2",
        "offset_y": "sin(siner / 4) * 10",
        "scale_y": "1.0 - sin(siner / 4) * 0.05"
      }
    }
  ]
}