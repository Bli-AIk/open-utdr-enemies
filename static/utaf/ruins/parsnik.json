{
  "name": "Parsnik",
  "fps": 30,
  "scale": 2,
  "canvasWidth": 164,
  "canvasHeight": 174,
  "variables": {
    "siner": {
      "type": "counter",
      "step": 1
    }
  },
  "sprites": {
    "parsnik_headwrap": "/sprites/parsnik/headwrap.png",
    "parsnik_snake1": [
      "/sprites/parsnik/snake1_0.png",
      "/sprites/parsnik/snake1_1.png",
      "/sprites/parsnik/snake1_2.png",
      "/sprites/parsnik/snake1_3.png"
    ],
    "parsnik_snake2": [
      "/sprites/parsnik/snake2_0.png",
      "/sprites/parsnik/snake2_1.png",
      "/sprites/parsnik/snake2_2.png",
      "/sprites/parsnik/snake2_3.png"
    ],
    "parsnik_snake3": [
      "/sprites/parsnik/snake3_0.png",
      "/sprites/parsnik/snake3_1.png",
      "/sprites/parsnik/snake3_2.png",
      "/sprites/parsnik/snake3_3.png"
    ],
    "parsnik_snake4": [
      "/sprites/parsnik/snake4_0.png",
      "/sprites/parsnik/snake4_1.png",
      "/sprites/parsnik/snake4_2.png",
      "/sprites/parsnik/snake4_3.png"
    ],
    "parsnik_snake5": [
      "/sprites/parsnik/snake5_0.png",
      "/sprites/parsnik/snake5_1.png",
      "/sprites/parsnik/snake5_2.png",
      "/sprites/parsnik/snake5_3.png"
    ],
    "parsnik_head": [
      "/sprites/parsnik/head_0.png",
      "/sprites/parsnik/head_1.png",
      "/sprites/parsnik/head_2.png",
      "/sprites/parsnik/head_3.png"
    ]
  },
  "parts": [
    {
      "id": "headwrap",
      "sprite": "parsnik_headwrap",
      "origin": { "x": -38, "y": -38 },
      "pivot": { "x": 0, "y": 0 },
      "drawOrder": 0,
      "expressions": {
        "offset_y": "sin(1.5 + siner / 5) * 2"
      }
    },
    {
      "id": "snake1",
      "sprite": "parsnik_snake1",
      "origin": { "x": -20, "y": -10 },
      "pivot": { "x": 16, "y": 19 },
      "drawOrder": 1,
      "expressions": {
        "offset_y": "sin(siner / 5) * 1.5",
        "rotation": "sin(siner / 5) * 6",
        "frame_index": "floor(siner / 6) % 4"
      }
    },
    {
      "id": "snake5",
      "sprite": "parsnik_snake5",
      "origin": { "x": 22, "y": -10 },
      "pivot": { "x": 0, "y": 18 },
      "drawOrder": 2,
      "expressions": {
        "offset_y": "sin(2 + siner / 5) * 1.5",
        "rotation": "-sin(2 + siner / 5) * 6",
        "frame_index": "floor((siner + 8) / 6) % 4"
      }
    },
    {
      "id": "snake2",
      "sprite": "parsnik_snake2",
      "origin": { "x": -14, "y": -16 },
      "pivot": { "x": 8, "y": 18 },
      "drawOrder": 3,
      "expressions": {
        "offset_y": "sin(0.5 + siner / 5) * 1.5",
        "rotation": "sin(siner / 5) * 2",
        "frame_index": "floor((siner + 2) / 5.5) % 4"
      }
    },
    {
      "id": "snake4",
      "sprite": "parsnik_snake4",
      "origin": { "x": 8, "y": -16 },
      "pivot": { "x": 0, "y": 19 },
      "drawOrder": 4,
      "expressions": {
        "offset_y": "sin(1.5 + siner / 5) * 1.5",
        "rotation": "-sin(siner / 5) * 2",
        "frame_index": "floor((siner + 6) / 5.5) % 4"
      }
    },
    {
      "id": "snake3",
      "sprite": "parsnik_snake3",
      "origin": { "x": 0, "y": -12 },
      "pivot": { "x": 8, "y": 34 },
      "drawOrder": 5,
      "expressions": {
        "offset_y": "sin(1 + siner / 5) * 1.5",
        "frame_index": "floor((siner + 4) / 5) % 4"
      }
    },
    {
      "id": "head",
      "sprite": "parsnik_head",
      "origin": { "x": -28, "y": -16 },
      "pivot": { "x": 0, "y": 0 },
      "drawOrder": 6,
      "expressions": {
        "frame_index": "floor(siner / 12) % 4"
      }
    }
  ]
}