{
  "name": "Migospel",
  "fps": 30,
  "scale": 2,
  "canvasWidth": 172,
  "canvasHeight": 196,
  "variables": {
    "siner": {
      "type": "counter",
      "step": 1
    }
  },
  "sprites": {
    "migospel_wingA": "/sprites/migospel/wingA.png",
    "migospel_wingB": "/sprites/migospel/wingB.png",
    "migospel_leg": "/sprites/migospel/leg.png",
    "migospel_body": "/sprites/migospel/body.png",
    "migospel_eye": [
      "/sprites/migospel/eye_0.png",
      "/sprites/migospel/eye_1.png",
      "/sprites/migospel/eye_2.png",
      "/sprites/migospel/eye_3.png",
      "/sprites/migospel/eye_4.png"
    ],
    "migospel_mouthA": [
      "/sprites/migospel/mouthA_0.png",
      "/sprites/migospel/mouthA_1.png"
    ],
    "migospel_eyeB": "/sprites/migospel/eyeB.png",
    "migospel_mouthB": "/sprites/migospel/mouthB.png",
    "migospel_mouthC": "/sprites/migospel/mouthC.png"
  },
  "states": {
    "normal": {
      "label": "普通",
      "default": true
    },
    "sad": {
      "label": "悲伤（独处）",
      "sprites": {
        "migospel_eye": [
          "/sprites/migospel/eye_0.png",
          "/sprites/migospel/eye_1.png",
          "/sprites/migospel/eye_2.png",
          "/sprites/migospel/eye_3.png",
          "/sprites/migospel/eye_4.png"
        ],
        "migospel_mouthA": "/sprites/migospel/mouthB.png"
      },
      "parts": {
        "body": {
          "expressions": {
            "offset_y": "0"
          }
        },
        "eyes": {
          "expressions": {
            "offset_y": "-20",
            "frame_index": "siner * 0.25"
          }
        },
        "mouth": {
          "expressions": {
            "offset_y": "0",
            "frame_index": "0"
          }
        }
      }
    },
    "pause": {
      "label": "受击",
      "sprites": {
        "migospel_eye": "/sprites/migospel/eyeB.png",
        "migospel_mouthA": "/sprites/migospel/mouthC.png"
      },
      "parts": {
        "body": {
          "expressions": {
            "offset_y": "0"
          }
        },
        "eyes": {
          "expressions": {
            "offset_y": "0",
            "frame_index": "0"
          }
        },
        "mouth": {
          "expressions": {
            "offset_y": "0",
            "frame_index": "0"
          }
        }
      }
    }
  },
  "parts": [
    {
      "id": "wing_a_left",
      "sprite": "migospel_wingA",
      "origin": { "x": -26, "y": 0 },
      "pivot": { "x": 11, "y": 14 },
      "drawOrder": 0,
      "expressions": {
        "offset_x": "sin(siner / 4) * 2",
        "offset_y": "sin(siner / 4) * 2"
      }
    },
    {
      "id": "wing_a_right",
      "sprite": "migospel_wingA",
      "origin": { "x": 26, "y": 0 },
      "pivot": { "x": 11, "y": 14 },
      "drawOrder": 1,
      "expressions": {
        "offset_x": "-sin(siner / 4) * 2",
        "offset_y": "sin(siner / 4) * 2",
        "scale_x": "-1"
      }
    },
    {
      "id": "wing_b_left",
      "sprite": "migospel_wingB",
      "origin": { "x": -26, "y": 14 },
      "pivot": { "x": 10, "y": 0 },
      "drawOrder": 2,
      "expressions": {
        "offset_x": "sin(siner / 4) * 2",
        "offset_y": "-sin(siner / 4) * 2"
      }
    },
    {
      "id": "wing_b_right",
      "sprite": "migospel_wingB",
      "origin": { "x": 26, "y": 14 },
      "pivot": { "x": 10, "y": 0 },
      "drawOrder": 3,
      "expressions": {
        "offset_x": "-sin(siner / 4) * 2",
        "offset_y": "-sin(siner / 4) * 2",
        "scale_x": "-1"
      }
    },
    {
      "id": "leg_left",
      "sprite": "migospel_leg",
      "origin": { "x": -26, "y": 42 },
      "pivot": { "x": 0, "y": 0 },
      "drawOrder": 4
    },
    {
      "id": "leg_right",
      "sprite": "migospel_leg",
      "origin": { "x": 24, "y": 42 },
      "pivot": { "x": 0, "y": 0 },
      "drawOrder": 5,
      "expressions": {
        "scale_x": "-1"
      }
    },
    {
      "id": "body",
      "sprite": "migospel_body",
      "origin": { "x": -26, "y": -58 },
      "pivot": { "x": 0, "y": 0 },
      "drawOrder": 6,
      "expressions": {
        "offset_y": "sin(siner / 6) * 2"
      }
    },
    {
      "id": "eyes",
      "sprite": "migospel_eye",
      "origin": { "x": -20, "y": -8 },
      "pivot": { "x": 0, "y": 0 },
      "drawOrder": 7,
      "expressions": {
        "offset_y": "sin(siner / 6) * 2 + (-clamp((siner % 180 - 90) * 0.8, 0, 16) + clamp((siner % 180 - 150) * 0.8, 0, 16))",
        "frame_index": "0"
      }
    },
    {
      "id": "mouth",
      "sprite": "migospel_mouthA",
      "origin": { "x": -18, "y": 8 },
      "pivot": { "x": 0, "y": 0 },
      "drawOrder": 8,
      "expressions": {
        "offset_y": "sin(siner / 6) * 2",
        "frame_index": "floor(clamp(siner % 51 - 40, 0, 2))"
      }
    }
  ]
}